generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum FitnessGoal {
  CUT
  BULK
  MAINTAIN
}

// 1. NEW: The isolated authentication table
model User {
  id           String    @id @default(uuid())
  username     String    @unique
  passwordHash String
  profile      Profile?
  createdAt    DateTime  @default(now())
}

model Profile {
  id             String        @id @default(uuid())
  // 2. NEW: Link the profile to a specific user
  userId         String        @unique
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role           Role          @default(ADMIN)
  birthDate      DateTime
  heightCm       Float
  gender         String
  currentGoal    FitnessGoal   @default(MAINTAIN)
  weeklyGoalRate Float
  metrics        BodyMetric[]
  workouts       Workout[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model BodyMetric {
  id               String   @id @default(uuid())
  profileId        String
  date             DateTime @default(now())
  weightKg         Float
  bodyFatPct       Float?
  calculatedTdee   Float
  targetCalories   Int
  targetProtein    Int
  profile          Profile  @relation(fields: [profileId], references: [id])

  @@unique([profileId, date])
}

model Exercise {
  id             String   @id @default(uuid())
  name           String   @unique
  muscleGroup    String
  isCompound     Boolean  @default(false)
  sets           Set[]
}

model Workout {
  id             String   @id @default(uuid())
  profileId      String
  date           DateTime @default(now())
  focus          String?
  durationMins   Int?
  notes          String?
  profile        Profile  @relation(fields: [profileId], references: [id])
  sets           Set[]
}

model Set {
  id             String   @id @default(uuid())
  workoutId      String
  exerciseId     String
  weightLbs      Float
  reps           Int
  rir            Int
  workout        Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise       Exercise @relation(fields: [exerciseId], references: [id])
  createdAt      DateTime @default(now())
}